# 1st sequence in word sheet
find_differential_duos <- function(sequence) {
  # Defined the 16 nucleic acid duos
  nucleic_acid_duos <- c("AT", "AA", "AG", "AC", 
                         "GG", "GC", "GA", "GT", 
                         "CC", "CT", "CG", "CA", 
                         "TT", "TA", "TC", "TG")
  
  # Initialized a list to store occurrences of each duo
  duo_occurrences <- list()
  for (duo in nucleic_acid_duos) {
    duo_occurrences[[duo]] <- c()
  }
  
  # Iterated through each pair of consecutive nucleotides
  for (i in 1:(nchar(sequence) - 1)) {
    duo <- substr(sequence, i, i + 1)  # Extract the current duo
    if (duo %in% nucleic_acid_duos) {
      duo_occurrences[[duo]] <- c(duo_occurrences[[duo]], i)
    }
  }
  
  return(duo_occurrences)
}

# Example usage:
sequence <- "1.	"
result <- find_differential_duos(sequence)
print(result)

