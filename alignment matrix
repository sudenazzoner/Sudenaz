create_scoring_matrix <- function() {
  matrix(
    c(2, -1, -1, -1,
      -1, 2, -1, -1,
      -1, -1, 2, -1,
      -1, -1, -1, 2),
    nrow = 4,
    ncol = 4,
    dimnames = list(c("A", "T", "G", "C"), c("A", "T", "G", "C"))
  )
}


generate_similarity_matrix <- function(seq1, seq2, scoring_matrix) {
  n <- nchar(seq1)
  m <- nchar(seq2)
  
  similarity_matrix <- matrix(0, nrow = n + 1, ncol = m + 1)
  

  for (i in 1:(n + 1)) similarity_matrix[i, 1] <- (i - 1) * -1
  for (j in 1:(m + 1)) similarity_matrix[1, j] <- (j - 1) * -1
  
 
  for (i in 2:(n + 1)) {
    for (j in 2:(m + 1)) {
      char_seq1 <- substr(seq1, i - 1, i - 1)
      char_seq2 <- substr(seq2, j - 1, j - 1)
      
      match_score <- scoring_matrix[char_seq1, char_seq2]
      similarity_matrix[i, j] <- max(
        similarity_matrix[i - 1, j - 1] + match_score,  # Match/mismatch
        similarity_matrix[i - 1, j] - 1,                # Deletion
        similarity_matrix[i, j - 1] - 1                 # Insertion
      )
    }
  }
  
  return(similarity_matrix)
}

# Function to perform traceback and get the best alignment
traceback <- function(similarity_matrix, seq1, seq2) {
  alignment1 <- ""
  alignment2 <- ""
  
  i <- nrow(similarity_matrix)
  j <- ncol(similarity_matrix)
  
  while (i > 1 && j > 1) {
    score_current <- similarity_matrix[i, j]
    score_diag <- similarity_matrix[i - 1, j - 1]
    score_up <- similarity_matrix[i - 1, j]
    score_left <- similarity_matrix[i, j - 1]
    
    char_seq1 <- substr(seq1, i - 1, i - 1)
    char_seq2 <- substr(seq2, j - 1, j - 1)
    
    if (score_current == score_diag + scoring_matrix[char_seq1, char_seq2]) {
      alignment1 <- paste0(char_seq1, alignment1)
      alignment2 <- paste0(char_seq2, alignment2)
      i <- i - 1
      j <- j - 1
    } else if (score_current == score_up - 1) {
      alignment1 <- paste0(char_seq1, alignment1)
      alignment2 <- paste0("-", alignment2)
      i <- i - 1
    } else {
      alignment1 <- paste0("-", alignment1)
      alignment2 <- paste0(char_seq2, alignment2)
      j <- j - 1
    }
  }
  
  while (i > 1) {
    char_seq1 <- substr(seq1, i - 1, i - 1)
    alignment1 <- paste0(char_seq1, alignment1)
    alignment2 <- paste0("-", alignment2)
    i <- i - 1
  }
  
  while (j > 1) {
    char_seq2 <- substr(seq2, j - 1, j - 1)
    alignment1 <- paste0("-", alignment1)
    alignment2 <- paste0(char_seq2, alignment2)
    j <- j - 1
  }
  
  return(list(alignment1 = alignment1, alignment2 = alignment2))
}

